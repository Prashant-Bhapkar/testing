# ── MinIO ──────────────────────────────────────────────────────
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_SECURE=true

# ── Qdrant ─────────────────────────────────────────────────────
QDRANT_URL=

# ── AI / LLM ───────────────────────────────────────────────────
AI_BASE_URL=
OPENAI_API_KEY=
EMBEDDING_MODEL=
CHAT_MODEL=
COLLECTION_NAME=documents

# ── Chunking ───────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=dociq

# ── JWT Auth ───────────────────────────────────────────────────
# Change JWT_SECRET to a long random string before deploying!
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRE_MINUTES=480

# ── Encryption key (for system passwords stored in DB) ─────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left blank, a key is derived from JWT_SECRET automatically.
ENCRYPTION_KEY=
